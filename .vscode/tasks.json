{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "check:ruff",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/ruff",
      "args": ["check", "bot", "scripts", "tests"],
      "group": "test"
    },
    {
      "label": "check:compile",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "py_compile",
        "bot/main.py",
        "bot/*.py",
        "scripts/*.py",
        "tests/*.py"
      ],
      "group": "test"
    },
    {
      "label": "check:migrations",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["scripts/migration_smoke.py"],
      "group": "test"
    },
    {
      "label": "check:tests",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "unittest",
        "discover",
        "-s",
        "tests",
        "-p",
        "'test_*.py'",
        "-b"
      ],
      "group": "test"
    },
    {
      "label": "check:all",
      "type": "shell",
      "dependsOrder": "sequence",
      "dependsOn": [
        "check:ruff",
        "check:compile",
        "check:migrations",
        "check:tests"
      ],
      "group": "test"
    },
    {
      "label": "report:economy",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "scripts/generation_economy_report.py",
        "--tau",
        "0.95",
        "--active-days",
        "7"
      ],
      "group": "test"
    },
    {
      "label": "report:rarity",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["scripts/rarity_odds.py"],
      "group": "test"
    }
  ]
}
