.env
.env.*
!.env.example

__pycache__/
*.py[cod]

# Generated local analysis artifacts
.VSCodeCounter/

# Runtime/persistent SQLite data
noodswap.db

# Mutable runtime state (host-mounted; never committed)
runtime/**/*

# Keep runtime structure placeholders
!runtime/db/
!runtime/db/.gitkeep
!runtime/card_images/
!runtime/card_images/.gitkeep
!runtime/frame_overlays/
!runtime/frame_overlays/.gitkeep
!runtime/fonts/
!runtime/fonts/.gitkeep
!runtime/logs/
!runtime/logs/.gitkeep
