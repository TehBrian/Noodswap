# Required for the bot to start.
DISCORD_TOKEN=replace-with-real-token

# Optional top.gg integration.
# TOPGG_WEBHOOK_SECRET=replace-with-topgg-webhook-secret
# TOPGG_BOT_ID=replace-with-discord-bot-id
# TOPGG_WEBHOOK_HOST=0.0.0.0
# TOPGG_WEBHOOK_PORT=8080
# TOPGG_WEBHOOK_PATH=/noodswap/topgg-vote-webhook
# TOPGG_WEBHOOK_MAX_BODY_BYTES=16384
# TOPGG_WEBHOOK_REQUIRE_JSON_CONTENT_TYPE=true
# TOPGG_WEBHOOK_ALLOWED_IPS=

# Runtime data roots inside the container.
DATA_DIR=/app/runtime
SQLITE_PATH=/app/runtime/db/bot.db
IMAGE_DIR=/app/runtime/card_images
FONTS_DIR=/app/runtime/fonts
FRAMES_DIR=/app/runtime/frames
